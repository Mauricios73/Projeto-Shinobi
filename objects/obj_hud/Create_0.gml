persistent = true;

// toggle do debug
dbg_show = false;     // começa ligado
dbg_key  = vk_f3;    // F3 liga/desliga

// fonte (opcional)
dbg_font = -1;       // se tiver uma fonte, coloca aqui (ex: fnt_debug)

// layout
pad = 16;
line_h = 18;

// cores básicas (sem depender de assets)
col_bg = make_color_rgb(0, 0, 0);
col_fg = make_color_rgb(255, 255, 255);
col_dim= make_color_rgb(170, 170, 170);
col_red= make_color_rgb(255, 80, 80);
col_blue=make_color_rgb(80, 150, 255);
col_yel= make_color_rgb(255, 220, 80);
col_grn= make_color_rgb(90, 255, 140);
